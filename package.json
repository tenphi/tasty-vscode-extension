{
  "name": "tasty-syntax-highlighting",
  "displayName": "Tasty Syntax Highlighting",
  "description": "Syntax highlighting for Tasty CSS-in-JS styles",
  "version": "3.0.3",
  "publisher": "cube-dev",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "tasty",
    "css-in-js",
    "syntax-highlighting",
    "react",
    "tsx",
    "typescript"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "vsce package"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.4",
    "@eslint/json": "^0.12.0",
    "@vscode/vsce": "^3.3.2",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3"
  },
  "contributes": {
    "grammars": [
      {
        "scopeName": "source.tasty",
        "path": "./syntaxes/tasty.tmLanguage.json",
        "injectTo": [
          "source.ts",
          "source.tsx",
          "source.js",
          "source.jsx"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.tasty": "css"
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tenphi/tasty-vscode-extension.git"
  },
  "license": "MIT"
}
