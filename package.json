{
  "name": "tasty-syntax-highlighting",
  "displayName": "Tasty Syntax Highlighting",
  "description": "Syntax highlighting for Tasty CSS-in-JS styles",
  "version": "3.0.0",
  "publisher": "cube-dev",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Programming Languages"],
  "keywords": [
    "tasty",
    "css-in-js",
    "syntax-highlighting",
    "react",
    "tsx",
    "typescript"
  ],
  "contributes": {
    "grammars": [
      {
        "scopeName": "source.tasty",
        "path": "./syntaxes/tasty.tmLanguage.json",
        "injectTo": [
          "source.ts",
          "source.tsx",
          "source.js",
          "source.jsx"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.tasty": "css"
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cube-js/cube.git"
  },
  "license": "MIT"
}
